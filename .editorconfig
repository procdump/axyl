# EditorConfig — consistent editor settings across the workspace.
# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Rust formatting is owned entirely by rustfmt.toml — `rustfmt` does not read
# .editorconfig, so a stanza here would either duplicate rustfmt.toml or
# silently disagree with it. Intentionally omitted.

# Web tooling and config formats conventionally use 2 spaces
[*.{js,mjs,cjs,ts,jsx,tsx,json,yml,yaml}]
indent_size = 2

# Solidity contracts
[*.sol]
indent_size = 4

# Makefiles require real tabs
[Makefile]
indent_style = tab

# Markdown: trailing whitespace can be a significant line break
[*.md]
trim_trailing_whitespace = false
