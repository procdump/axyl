graph LR
    subgraph NA["Node A"]
        direction TB
        P1["ReportBatch"]
        P2["RequestBatches"]
        P3["PeerExchange"]

        G1["Batch"]
        G2["Txn"]
    end

    subgraph NB["Node B"]
        direction TB
        Q1["QuorumReqRes { ContinueAfterQuorum }<br/>Target: AnyPeer<br/>Store batch if valid.<br/>If validator: produce ack.<br/>Forward to all peers (excl. prev_hop).<br/>Merge local + downstream acks.<br/>Return partial aggregate upstream."]
        Q2["AnyPeerReqRes<br/>Target: AnyPeer<br/>Check local DB for requested batches.<br/>Return if found; otherwise<br/>forward to peers.<br/>Respect max_response_size.<br/>Deduplicate by batch digest."]
        Q3["Intercepted by network layer.<br/>Handled internally."]

        R1["Unchanged.<br/>Auto-broadcast by GossipSub."]
        R2["Unchanged.<br/>Auto-broadcast by GossipSub."]
    end

    %% P2P Request-Response (upgraded to relay)
    P1 -->|"QuorumReqRes<br/>ContinueAfterQuorum"| Q1
    P2 -->|"AnyPeerReqRes<br/>AnyPeer"| Q2
    P3 -->|" "| Q3

    %% Gossip (unchanged)
    G1 -.->|"rayls_batches"| R1
    G2 -.->|"rayls_txns"| R2

    %% Architectural note
    NOTE["All 6 P2P messages use application-level request/response relay.<br/>Each hop uses libp2p request_response between directly connected peers.<br/>The relay layer handles multi-hop forwarding, deduplication (request_id + LRU),<br/>partial aggregation (QuorumReqRes), and loop prevention.<br/>Relayed via application-level request/response. No direct connection required.<br/><br/>Validators no longer need direct connections to all committee peers.<br/>Observers can connect to any relay node instead of requiring a direct validator connection."]
    style NOTE fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
