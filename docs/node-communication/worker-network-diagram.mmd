graph LR
    subgraph NA["Node A"]
        direction TB
        P1["ReportBatch"]
        P2["RequestBatches"]
        P3["PeerExchange"]

        G1["Batch"]
        G2["Txn"]
    end

    subgraph NB["Node B"]
        direction TB
        Q1["Validate, store batch,<br/>notify local primary.<br/>Requires direct connection.<br/>Does not broadcast."]
        Q2["Read DB and return batches.<br/>Requires direct connection.<br/>Does not broadcast."]
        Q3["Intercepted by network layer.<br/>Handled internally.<br/>Requires direct connection.<br/>Does not broadcast."]

        R1["Check if batch exists;<br/>if missing, fetch via P2P.<br/>No direct connection.<br/>Auto-broadcast by GossipSub."]
        R2["If designated authority,<br/>submit to BatchBuilder.<br/>No direct connection.<br/>Auto-broadcast by GossipSub."]
    end

    %% P2P Request-Response
    P1 -->|" "| Q1
    P2 -->|" "| Q2
    P3 -->|" "| Q3

    %% Gossip
    G1 -.->|"rayls_batches"| R1
    G2 -.->|"rayls_txns"| R2

    NOTE["P2P messages require direct connections between nodes.<br/>All validators must maintain direct connections to each other.<br/>Observers need at least one direct connection to a validator."]
    style NOTE fill:#fff3e0,stroke:#e65100,stroke-width:2px
