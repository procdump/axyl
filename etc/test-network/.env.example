# indicates if the network should start or just generate config files
START="true"

# Account that will be funded with 1 billion RLS for testing.
# You must use --dev-funds to overide with your own account,
# must be prefixed with 0x and be a valid account.
DEV_FUNDS=""

BASEFEE_ADDRESS=""

# Indicates whether first validator will be profilied for memory. Possible values: 0 or 1
HEAPTRACK="0"

# Number of threads that compiler will use. The default is total number of cores
COMPILER_THREADS=""

# Number of validator nodes to run (default 4)
NUM_VALIDATORS=4

# Number of observer nodes to run (default 1)
NUM_OBSERVERS=1

# Epoch duration in seconds. If not set or not number, defaults to 86400 (1 day).
EPOCH_DURATION=86400

# Build mode (release or debug)
BUILD_CONFIG="release"

# Log level ("q", "v", "vv", "vvv", "vvvv" where "q" is for nothing and "vvvv" is for most verbose)
LOG_LEVEL="vv"

# DB grow step (leave empty for default)
DB_GROW_STEP=""

# Run nodes with high priority (0 or 1)
USE_HIGH_PRIORITY=""

# Expose WS services (0 or 1)
EXPOSE_WS="0"

# Rayls network hardfork profile (devnet, testnet, mainnet).
# Overrides the `network` field in parameters.yaml at node startup.
RAYLS_NETWORK="devnet"

# Use higher tx pool imits for dev (0 or 1)
TX_POOL_LARGE_LIMITS="1"

# Gasless mode: set to "true" to create a gasless (feeless) network.
# Sets --base-fee 0 --min-base-fee 0 during genesis.
GASLESS=""

# Custom block gas limit (in gas units). Leave empty for default (500M).
GAS_LIMIT=""

# Observer only: run observers as a full archive (drops `--full`, so
# account/storage history is not pruned) — use when an observer's datadir will
# seed `rayls-replay`. Left unset so an inline `DISABLE_PRUNING=1 ./local-testnet.sh`
# is not overwritten when this file is sourced; uncomment to enable via .env.
# DISABLE_PRUNING=1


RL_BLS_PASSPHRASE="local"
