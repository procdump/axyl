# Normalize line endings: store text as LF in the repo and check out as LF.
# Protects against CRLF being committed from Windows checkouts.
* text=auto eol=lf

# Shell scripts must stay LF even on Windows checkouts
*.sh text eol=lf

# Windows-native scripts keep CRLF
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files — never normalize or diff
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.pdf  binary
*.wasm binary
*.bin  binary

# Generated / vendored — collapse diffs and exclude from GitHub language stats
Cargo.lock linguist-generated=true
rayls-contracts/artifacts/** linguist-generated=true
