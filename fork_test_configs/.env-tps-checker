# =============================================================================
# Transaction Configuration (Required)
# =============================================================================

# Total number of transactions to send
NUM_TRANSACTIONS=100000000

# Chain ID (required for EIP-155 signing)
CHAIN_ID=487
#CHAIN_ID=123123
#CHAIN_ID=503

# =============================================================================
# Batch Configuration (Optional)
# =============================================================================

# Number of transactions per RPC batch (default: 4096)
# Larger batches = fewer RPC calls, but more memory usage
# Batches never cross wallet boundaries
BATCH_SIZE=4096

# Maximum concurrent batch submissions (default: 20)
# Higher values = more parallelism, but more RPC load
CONCURRENT_BATCHES=20

# =============================================================================
# Transaction Parameters (Optional)
# =============================================================================

# Gas price in wei (default: 1 gwei = 1000000000)
GAS_PRICE=200000000000
#GAS_PRICE=0

# Gas limit per transaction (default: 21000 for simple transfers)
GAS_LIMIT=21000

# Value to transfer in wei (default: 1000)
TX_VALUE=1000

# Receiver address (default: dead address 0x...dEaD)
RECEIVER_ADDRESS="0x000000000000000000000000000000000000dEaD"

# =============================================================================
# Polling Configuration (Optional)
# =============================================================================

# Initial polling interval in milliseconds (default: 25)
POLL_INITIAL_MS=25

# Maximum polling interval in milliseconds (default: 200)
# Polling uses exponential backoff between initial and max
POLL_MAX_MS=200

# Maximum polling attempts before timeout (default: 600)
# Total timeout = max_attempts * max_interval = 600 * 200ms = 120s
POLL_MAX_ATTEMPTS=600

# =============================================================================
# Auto-Funding Configuration (Optional)
# =============================================================================

# Private key of the funder account (hex format, with or without 0x prefix).
# When provided, wallets with insufficient balance will be automatically funded.
# WARNING: Use test keys only! Never commit production private keys.
#FUNDER_PRIVATE_KEY="9cc03222f569665f682b715213ecf9f9bcf80bab201fccf6449c543775c371b7"
FUNDER_PRIVATE_KEY="0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80"
#FUNDER_PRIVATE_KEY="0x7ecf2546356e8009833c7c193591628e98661b8b5128ce8bc6b38cd735e19873"
#FUNDER_PRIVATE_KEY="0x8dc9e6a0805c1df560f9370597bc15452e0bbdaac86161496477173773545c42"

# Amount to fund each wallet in wei (optional).
# If not specified, defaults to required_balance + 10% margin.
# Example: 1 ETH = 1000000000000000000
# FUND_AMOUNT=100000000000000000000000000  # Commented out to use auto-calculation

# Skip auto-funding even if funder key is provided (default: false).
#SKIP_FUNDING=false

# Maximum concurrent funding transactions (default: 10).
# Higher values = faster funding, but more RPC load.
# FUNDING_CONCURRENCY=10

